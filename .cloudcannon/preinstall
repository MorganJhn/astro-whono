#!/bin/bash
# Upgrade npm to avoid "Exit handler never called" bug in npm 10.9.4
npm install -g npm@11.12.1 --force 2>/dev/null
# Export path so subsequent commands use new npm
export PATH="$(npm config get prefix)/bin:$PATH"
# Also set npm config to skip update checks
npm config set audit false
npm config set fund false
npm config set prefer-offline true
